#!/bin/bash
# Post-merge hook: update the project memory store after merging to main.
# Install: git config core.hooksPath .githooks

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MEMORY_SCRIPT="$SCRIPT_DIR/.agent/memory/project-memory"
MEMORY_DB="$SCRIPT_DIR/.agent/memory/project_memory.db"

if [ ! -f "$MEMORY_SCRIPT" ]; then
    echo "project_memory.py not found, skipping memory build"
    exit 0
fi

echo "Building project memory..."
VENV_PYTHON="$SCRIPT_DIR/.agent/memory/.venv/bin/python"
PYTHON="${VENV_PYTHON:-python3}"
[ -f "$VENV_PYTHON" ] && PYTHON="$VENV_PYTHON"
"$PYTHON" "$MEMORY_SCRIPT" build || {
    echo "Warning: memory build failed (non-fatal)"
    exit 0
}

if [ -f "$MEMORY_DB" ]; then
    git add "$MEMORY_DB"
    git commit -m "chore: update project memory store" --no-verify || true
fi
